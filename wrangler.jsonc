{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "porhai",
  "main": "worker.ts",
  "compatibility_date": "2026-06-08",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "build": {
    "command": "npm run build",
    "watch_dir": "src",
  },
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets",
  },
  "images": {
    "binding": "IMAGES",
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "porhai",
    },
  ],
  "observability": {
    "enabled": true,
  },
  "upload_source_maps": true,
  "minify": true,
  // 1. Configure Hyperdrive for decentralized storage
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "19ad010c64dc4b849feef5f674d06f6d",
      "localConnectionString": "postgresql://neondb_owner:npg_eCRnO5Li2vUY@ep-dawn-queen-ao35phwy-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require",
    },
  ],

  // 2. Configure queues for background processing
  "queues": {
    "producers": [
      {
        "queue": "porhai-queue",
        "binding": "QUEUE",
      },
    ],
    "consumers": [
      {
        "queue": "porhai-queue",
        "max_batch_size": 10,
        "max_retries": 5,
      },
    ],
  },
  // 3. Configure KV namespaces for key-value storage
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "82b5a7209be6489590576c6c4d3e77d2",
    },
  ],

  // 4. Configure Workflows for orchestrating complex tasks
  "workflows": [
    {
      "name": "porhai-workflow",
      "binding": "WORKFLOWS",
      "class_name": "PorhaiWorkflow",
    },
  ],
  // 5. Configure Durable Objects for real-time chat state management
  "durable_objects": {
    "bindings": [
      {
        "name": "CHAT_ROOM_DO",
        "class_name": "ChatRoomDO",
      },
    ],
  },

  // 6. Migrations for Durable Objects
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChatRoomDO"],
    },
  ],

  // 7. Configure Workers AI for PDF Embeddings and LLM Chat
  "ai": {
    "binding": "AI",
  },
}
